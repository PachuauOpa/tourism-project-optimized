# Backend
PORT=4000

# Admin credentials (change in production)
ILP_ADMIN_USERNAME=admin
ILP_ADMIN_PASSWORD=admin123

# Supabase project + storage
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_BUCKET=mizTour
SUPABASE_SIGNED_URL_TTL_SECONDS=3600
PUBLIC_API_BASE_URL=

# Supabase Postgres connection
# Use either SUPABASE_DB_URL or the individual SUPABASE_DB_* values.
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_HOST=aws-0-ap-south-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
SUPABASE_DB_SSL=true

# Razorpay Payment Gateway
# Get these from the Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
# Get the webhook secret from Razorpay Dashboard → Webhooks → Add Webhook
RAZORPAY_WEBHOOK_SECRET=YOUR_RAZORPAY_WEBHOOK_SECRET
# ILP pass fee in paise (5000 = ₹50)
ILP_PAYMENT_AMOUNT_PAISE=5000
